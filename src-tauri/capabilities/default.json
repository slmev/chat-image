{
  "identifier": "default",
  "description": "Main window permissions for local image persistence and export.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "store:default",
    "opener:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/images/**" }
      ]
    },
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-stat",
    "fs:allow-write-file",
    "fs:allow-remove",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    }
  ]
}
